---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Blog | Eddie Carrasco">
	<section class="cyber-terminal">
		<div class="cyber-terminal__chrome">
			<div class="cyber-terminal__dots">
				<span class="cyber-terminal__dot"></span>
				<span class="cyber-terminal__dot"></span>
				<span class="cyber-terminal__dot"></span>
			</div>
			<span class="cyber-terminal__title">blog.feed</span>
		</div>
		<div class="cyber-terminal__body">
			<div class="cyber-terminal__line">
				<span class="cyber-terminal__prompt">$</span>
				<span class="cyber-terminal__command">list thoughts --topic engineering,ai</span>
			</div>
			<p>Articles, notes, and lessons learned from building software and exploring AI tooling.</p>
		</div>
	</section>
</Layout>
